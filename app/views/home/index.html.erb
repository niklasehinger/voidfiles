<div class="min-h-screen bg-[#101828] flex flex-col relative overflow-hidden">
  <!-- Header mit Navigation -->
  <header class="w-full flex items-center justify-between px-8 py-6 bg-[#101828] border-b border-[#1E2B49]/60 z-20">
    <span class="text-white text-2xl font-bold tracking-wide">VoidFiles</span>
    <nav class="flex gap-8 text-[#9299A5] font-medium">
      <a href="#" class="hover:text-[#615EFF] transition">Projekte</a>
      <a href="#" class="hover:text-[#615EFF] transition">Analysen</a>
      <a href="#" class="hover:text-[#615EFF] transition">Einstellungen</a>
    </nav>
  </header>

  <!-- Hauptinhalt -->
  <main class="flex flex-col justify-center items-start w-full max-w-3xl px-6 py-24 lg:py-40 mx-auto">
    <div class="mb-6 flex items-center gap-3">
      <span class="bg-[#1E2B49] text-[#615EFF] text-xs font-semibold px-3 py-1 rounded-full">Was ist neu</span>
      <span class="text-[#9299A5] text-xs">VoidFiles v1.0</span>
    </div>
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white mb-6 leading-tight">
      Projektdateien aufräumen<br class="hidden sm:block" /> mit KI – schnell & sicher
    </h1>
    <p class="text-lg text-[#9299A5] mb-10 max-w-2xl">
      VoidFiles ist ein SaaS-Tool für Videoeditoren, das Adobe Premiere Pro <code class="bg-[#1E2B49] px-1 rounded text-[#615EFF]">.prproj</code>-Dateien analysiert, um verwendete, ungenutzte und fehlende Mediendateien zu identifizieren. Spare Speicherplatz, archiviere Footage strukturiert und behalte den Überblick – unterstützt durch GPT-4.
    </p>
    <div class="flex gap-4 mb-12">
      <a href="#" class="bg-[#615EFF] hover:bg-[#4b47cc] text-white font-semibold px-6 py-3 rounded-lg shadow transition">Jetzt starten</a>
      <a href="#" class="text-[#615EFF] font-semibold px-6 py-3 rounded-lg hover:underline flex items-center gap-2">Mehr erfahren <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg></a>
    </div>
    <div class="flex flex-col sm:flex-row gap-4">
      <div class="flex items-center gap-2 bg-[#1E2B49] rounded px-4 py-2 text-white text-sm">
        <span class="text-green-400 text-lg">✅</span> Used
      </div>
      <div class="flex items-center gap-2 bg-[#1E2B49] rounded px-4 py-2 text-white text-sm">
        <span class="text-yellow-400 text-lg">📁</span> Unused
      </div>
      <div class="flex items-center gap-2 bg-[#1E2B49] rounded px-4 py-2 text-white text-sm">
        <span class="text-red-500 text-lg">❌</span> Missing
      </div>
    </div>
  </main>

  <!-- Hintergrundraster (dezent) -->
  <div class="absolute inset-0 z-0 pointer-events-none">
    <svg class="w-full h-full" width="100%" height="100%" fill="none">
      <defs>
        <pattern id="grid" width="64" height="64" patternUnits="userSpaceOnUse">
          <path d="M 64 0 V 64 H 0" fill="none" stroke="#1E2B49" stroke-width="1" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid)" />
    </svg>
  </div>
</div> 